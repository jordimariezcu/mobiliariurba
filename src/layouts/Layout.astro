---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noSuffix?: boolean;
  jsonLd?: string;
  noIndex?: boolean;
}
const {
  title,
  description = 'Portal en català sobre jocs infantils, circuits esportius i mobiliari urbà per a tècnics municipals i arquitectes de Catalunya. Normativa EN1176, materials i subvencions.',
  canonical,
  ogImage = '/og-default.png',
  ogType = 'website',
  noSuffix = false,
  jsonLd,
  noIndex = false,
} = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, 'https://mobiliariurba.cat').toString();
const pageTitle = noSuffix ? title : `${title} | MobiliariUrbà.cat`;
const ogImageURL = ogImage.startsWith('http') ? ogImage : `https://mobiliariurba.cat${ogImage}`;
---
<!doctype html>
<html lang="ca">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noIndex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="ca" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#1a6b3a" />
    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="MobiliariUrbà.cat" />
    <meta property="og:locale" content="ca_ES" />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <!-- JSON-LD -->
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap.xml" />
    <!-- Analytics -->
    <script defer src="https://umami-production-c3fa.up.railway.app/script.js" data-website-id="fbd04185-24ba-4017-bdcb-4eaedb05b96e"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="logo">
          <span class="logo-text">Mobiliari<strong>Urbà</strong><span class="tld">.cat</span></span>
        </a>
        <nav class="main-nav">
          <div class="nav-group has-dropdown">
            <a href="/productes">Productes</a>
            <div class="dropdown">
              <div class="dropdown-col">
                <p class="dropdown-label">Jocs i Esport</p>
                <a href="/productes/jocs-infantils">Jocs Infantils</a>
                <a href="/productes/jocs-infantils/gronxadors-i-balancins">Gronxadors i Balancins</a>
                <a href="/productes/jocs-infantils/tobogans">Tobogans</a>
                <a href="/productes/jocs-infantils/jocs-inclusius">Jocs Inclusius</a>
                <a href="/productes/jocs-infantils/circuits-multijoc">Circuits Multijoc</a>
                <a href="/productes/circuit-esportiu">Circuit Esportiu</a>
              </div>
              <div class="dropdown-col">
                <p class="dropdown-label">Gent Gran</p>
                <a href="/productes/aparells-biosaludables">Aparells Biosaludables</a>
                <a href="/productes/aparells-biosaludables/aparells-gent-gran">Aparells per a Gent Gran</a>
                <a href="/productes/aparells-biosaludables/circuits-passeig">Circuits de Passeig</a>
                <p class="dropdown-label" style="margin-top:0.75rem;">Mobiliari</p>
                <a href="/productes/bancs">Bancs</a>
                <a href="/productes/fonts-i-bebedors">Fonts i Bebedors</a>
                <a href="/productes/taules-de-picnic">Taules de Pícnic</a>
                <a href="/productes/papereres">Papereres</a>
                <a href="/productes/pilones-i-bolards">Pilones i Bolards</a>
                <a href="/productes/alcorques">Alcorques</a>
              </div>
              <div class="dropdown-col">
                <p class="dropdown-label">Guies tècniques</p>
                <a href="/guia/parcs-infantils">Guia Parcs Infantils</a>
                <a href="/guia/normativa-en1176">Normativa EN1176</a>
                <a href="/guia/espais-gent-gran">Espais per a Gent Gran</a>
              </div>
            </div>
          </div>
          <a href="/guia/parcs-infantils">Guies</a>
          <a href="/blog">Blog</a>
          <a href="/projectes">Projectes</a>
          <a href="/contacte" class="nav-cta">Contacte</a>
        </nav>
        <button class="menu-toggle" aria-label="Obrir menú">☰</button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <a href="/" class="logo">
              <span class="logo-text">Mobiliari<strong>Urbà</strong><span class="tld">.cat</span></span>
            </a>
            <p>El portal de referència en català sobre equipament i mobiliari urbà per a municipis, parcs i espais públics.</p>
          </div>
          <div>
            <h4>Jocs i Esport</h4>
            <ul>
              <li><a href="/productes/jocs-infantils">Jocs Infantils</a></li>
              <li><a href="/productes/jocs-infantils/gronxadors-i-balancins">Gronxadors i Balancins</a></li>
              <li><a href="/productes/jocs-infantils/tobogans">Tobogans</a></li>
              <li><a href="/productes/jocs-infantils/jocs-inclusius">Jocs Inclusius</a></li>
              <li><a href="/productes/circuit-esportiu">Circuit Esportiu</a></li>
            </ul>
          </div>
          <div>
            <h4>Gent Gran i Mobiliari</h4>
            <ul>
              <li><a href="/productes/aparells-biosaludables">Aparells Biosaludables</a></li>
              <li><a href="/productes/aparells-biosaludables/circuits-passeig">Circuits de Passeig</a></li>
              <li><a href="/productes/bancs">Bancs</a></li>
              <li><a href="/productes/taules-de-picnic">Taules de Pícnic</a></li>
              <li><a href="/productes/fonts-i-bebedors">Fonts i Bebedors</a></li>
            </ul>
          </div>
          <div>
            <h4>Recursos</h4>
            <ul>
              <li><a href="/guia/parcs-infantils">Guia Parcs Infantils</a></li>
              <li><a href="/guia/normativa-en1176">Normativa EN1176</a></li>
              <li><a href="/guia/espais-gent-gran">Espais Gent Gran</a></li>
              <li><a href="/blog">Blog Tècnic</a></li>
              <li><a href="/contacte">Contacte</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p class="copyright">&copy; {new Date().getFullYear()} MobiliariUrbà.cat — Portal de referència en català sobre equipament urbà.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --color-primary: #1a6b3a;
    --color-primary-dark: #124d2a;
    --color-primary-light: #e8f5ee;
    --color-accent: #f0a500;
    --color-accent-dark: #d4900a;
    --color-text: #1f2937;
    --color-muted: #6b7280;
    --color-bg: #ffffff;
    --color-bg-alt: #f8f9fa;
    --color-border: #e5e7eb;
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --radius: 8px;
    --radius-lg: 12px;
    --shadow: 0 2px 8px rgba(0,0,0,0.08);
    --shadow-md: 0 4px 16px rgba(0,0,0,0.12);
  }

  html { font-family: var(--font-sans); color: var(--color-text); background: var(--color-bg); scroll-behavior: smooth; }
  body { min-height: 100vh; display: flex; flex-direction: column; }
  main { flex: 1; }
  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }
  ul { list-style: none; }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

  /* ── Header ── */
  .site-header {
    position: sticky; top: 0; z-index: 100;
    background: white; border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow);
  }
  .site-header .container {
    display: flex; align-items: center; justify-content: space-between;
    height: 68px; gap: 2rem;
  }
  .logo { display: flex; align-items: center; }
  .logo-text { font-size: 1.2rem; font-weight: 700; letter-spacing: -0.02em; color: var(--color-primary); white-space: nowrap; }
  .logo-text strong { color: var(--color-primary-dark); }
  .logo-text .tld { color: var(--color-accent); font-weight: 800; }

  /* ── Nav ── */
  .main-nav { display: flex; align-items: center; gap: 0.25rem; }
  .main-nav > a, .nav-group > a {
    padding: 0.5rem 0.75rem; border-radius: var(--radius);
    font-weight: 500; font-size: 0.9rem; color: var(--color-text); transition: all 0.15s;
    white-space: nowrap;
  }
  .main-nav > a:hover, .nav-group > a:hover { background: var(--color-bg-alt); color: var(--color-primary); }
  .nav-cta {
    background: var(--color-primary) !important; color: white !important;
    padding: 0.5rem 1.25rem !important; margin-left: 0.5rem;
  }
  .nav-cta:hover { background: var(--color-primary-dark) !important; }

  /* Dropdown */
  .nav-group { position: relative; }
  .dropdown {
    display: none; position: absolute; top: calc(100% + 8px); left: 0;
    background: white; border: 1px solid var(--color-border); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md); padding: 1.25rem; min-width: 560px;
    display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem;
    opacity: 0; pointer-events: none; transform: translateY(-4px); transition: all 0.15s;
  }
  .nav-group:hover .dropdown { opacity: 1; pointer-events: all; transform: translateY(0); }
  .dropdown-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-muted); font-weight: 700; margin-bottom: 0.5rem; }
  .dropdown a { display: block; padding: 0.3rem 0; font-size: 0.875rem; color: var(--color-text); transition: color 0.15s; }
  .dropdown a:hover { color: var(--color-primary); }

  .menu-toggle { display: none; background: none; border: none; font-size: 1.5rem; cursor: pointer; }

  /* ── Footer ── */
  .site-footer { background: #111827; color: #9ca3af; padding: 3.5rem 0 1.5rem; margin-top: 5rem; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 2.5rem; margin-bottom: 2.5rem; }
  .site-footer .logo-text { color: white; display: block; margin-bottom: 0.75rem; font-size: 1.1rem; }
  .site-footer p { font-size: 0.875rem; line-height: 1.6; }
  .site-footer h4 { color: white; margin-bottom: 0.75rem; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .site-footer li { margin-bottom: 0.4rem; }
  .site-footer a { font-size: 0.875rem; transition: color 0.15s; }
  .site-footer a:hover { color: white; }
  .footer-bottom { border-top: 1px solid #1f2937; padding-top: 1.5rem; }
  .copyright { font-size: 0.8rem; color: #4b5563; }

  /* ── Utilitats globals ── */
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    padding: 0.75rem 1.75rem; border-radius: var(--radius);
    font-weight: 600; font-size: 0.95rem; transition: all 0.2s; cursor: pointer; border: none;
    text-decoration: none;
  }
  .btn-primary { background: var(--color-primary); color: white; }
  .btn-primary:hover { background: var(--color-primary-dark); }
  .btn-accent { background: var(--color-accent); color: #1f2937; }
  .btn-accent:hover { background: var(--color-accent-dark); }
  .btn-outline { border: 2px solid var(--color-primary); color: var(--color-primary); background: transparent; }
  .btn-outline:hover { background: var(--color-primary); color: white; }
  .btn-lg { padding: 1rem 2.5rem; font-size: 1.05rem; }

  .section { padding: 4rem 0; }
  .section-alt { background: var(--color-bg-alt); }
  .section-title { font-size: 1.875rem; font-weight: 700; margin-bottom: 0.5rem; line-height: 1.2; }
  .section-subtitle { color: var(--color-muted); font-size: 1.05rem; margin-bottom: 2rem; }
  .section-cta { text-align: center; margin-top: 2.5rem; }

  .page-header { background: var(--color-bg-alt); padding: 2.5rem 0; border-bottom: 1px solid var(--color-border); }
  .page-header h1 { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 800; line-height: 1.15; }
  .page-header p { color: var(--color-muted); margin-top: 0.5rem; font-size: 1.05rem; max-width: 640px; }

  .breadcrumb { font-size: 0.85rem; color: var(--color-muted); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.35rem; flex-wrap: wrap; }
  .breadcrumb a:hover { color: var(--color-primary); }
  .breadcrumb span { color: var(--color-muted); }

  .grid-3 { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
  .grid-4 { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem; }

  .card {
    background: white; border-radius: var(--radius-lg); overflow: hidden;
    border: 1px solid var(--color-border); transition: box-shadow 0.2s, transform 0.2s;
    display: flex; flex-direction: column;
  }
  .card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .card-img { aspect-ratio: 4/3; overflow: hidden; background: var(--color-bg-alt); }
  .card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
  .card:hover .card-img img { transform: scale(1.03); }
  .placeholder-img { width: 100%; height: 100%; background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%); display: flex; align-items: center; justify-content: center; font-size: 3rem; }
  .card-body { padding: 1.25rem; flex: 1; display: flex; flex-direction: column; }
  .card-body h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.375rem; }
  .card-body p { font-size: 0.875rem; color: var(--color-muted); line-height: 1.5; flex: 1; }

  .badge {
    display: inline-flex; align-items: center; gap: 0.25rem;
    padding: 0.2rem 0.6rem; border-radius: 99px;
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
  }
  .badge-green { background: #dcfce7; color: #166534; }
  .badge-blue { background: #dbeafe; color: #1e40af; }
  .badge-orange { background: #ffedd5; color: #9a3412; }

  .tag-list { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.75rem; }
  .tag { padding: 0.2rem 0.6rem; background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: 99px; font-size: 0.75rem; color: var(--color-muted); }

  .prose h2 { font-size: 1.5rem; font-weight: 700; margin: 2rem 0 0.75rem; }
  .prose h3 { font-size: 1.15rem; font-weight: 700; margin: 1.5rem 0 0.5rem; color: var(--color-primary-dark); }
  .prose p { margin-bottom: 1rem; line-height: 1.75; }
  .prose ul, .prose ol { margin: 0.75rem 0 1rem 1.5rem; }
  .prose li { margin-bottom: 0.4rem; line-height: 1.6; }
  .prose strong { color: var(--color-primary-dark); }
  .prose a { color: var(--color-primary); text-decoration: underline; }
  .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9rem; }
  .prose th { background: var(--color-primary); color: white; padding: 0.6rem 1rem; text-align: left; }
  .prose td { padding: 0.6rem 1rem; border-bottom: 1px solid var(--color-border); }
  .prose tr:nth-child(even) td { background: var(--color-bg-alt); }

  .info-box { background: var(--color-primary-light); border-left: 4px solid var(--color-primary); padding: 1.25rem 1.5rem; border-radius: 0 var(--radius) var(--radius) 0; margin: 1.5rem 0; }
  .info-box p { margin: 0; font-size: 0.9rem; line-height: 1.6; }

  @media (max-width: 1024px) {
    .dropdown { grid-template-columns: 1fr 1fr; min-width: 380px; }
  }
  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .main-nav { display: none; }
    .menu-toggle { display: block; }
    .dropdown { display: none !important; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
