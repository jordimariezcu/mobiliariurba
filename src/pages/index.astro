---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);

const productes = await reader.collections.productes.all();
const projectes = await reader.collections.projectes.all();

const destacats = productes.filter(p => p.entry.destacat).slice(0, 6);
const projectesDestacats = projectes.filter(p => p.entry.destacat).slice(0, 3);
---

<Layout title="Inici">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1>Mobiliari Urbà<br />per a espais públics</h1>
        <p>Solucions de qualitat per a municipis, parcs, places i espais urbans. Disseny durador, funcional i sostenible.</p>
        <div class="hero-actions">
          <a href="/productes" class="btn btn-primary">Veure productes</a>
          <a href="/projectes" class="btn btn-outline">Els nostres projectes</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Productes destacats -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Productes destacats</h2>
      {destacats.length > 0 ? (
        <div class="grid-3">
          {destacats.map(p => (
            <a href={`/productes/${p.slug}`} class="card">
              {p.entry.imatge && (
                <div class="card-img">
                  <img src={p.entry.imatge} alt={p.entry.nom} loading="lazy" />
                </div>
              )}
              <div class="card-body">
                <span class="badge">{p.entry.categoria}</span>
                <h3>{p.entry.nom}</h3>
                {p.entry.material && <p class="text-muted">{p.entry.material}</p>}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="grid-3">
          {['Bancs', 'Papereres', 'Jardineres'].map(cat => (
            <a href={`/productes?categoria=${cat.toLowerCase()}`} class="card card-placeholder">
              <div class="card-img placeholder-img"></div>
              <div class="card-body">
                <h3>{cat}</h3>
              </div>
            </a>
          ))}
        </div>
      )}
      <div class="section-cta">
        <a href="/productes" class="btn btn-primary">Veure tots els productes</a>
      </div>
    </div>
  </section>

  <!-- Projectes -->
  {projectesDestacats.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <h2 class="section-title">Projectes recents</h2>
        <div class="grid-3">
          {projectesDestacats.map(p => (
            <a href={`/projectes/${p.slug}`} class="card">
              {p.entry.imatge && (
                <div class="card-img">
                  <img src={p.entry.imatge} alt={p.entry.titol} loading="lazy" />
                </div>
              )}
              <div class="card-body">
                <h3>{p.entry.titol}</h3>
                {p.entry.ubicacio && <p class="text-muted">{p.entry.ubicacio} · {p.entry.any}</p>}
              </div>
            </a>
          ))}
        </div>
        <div class="section-cta">
          <a href="/projectes" class="btn btn-outline-dark">Tots els projectes</a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA contacte -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Necessiteu mobiliari per al vostre municipi?</h2>
        <p>Contacteu-nos i us assessorarem sense compromís.</p>
        <a href="/contacte" class="btn btn-accent">Contactar ara</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
    color: white;
    padding: 5rem 0;
  }
  .hero-content { max-width: 600px; }
  .hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.1; margin-bottom: 1.25rem; }
  .hero p { font-size: 1.125rem; opacity: 0.9; margin-bottom: 2rem; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn {
    display: inline-flex; align-items: center;
    padding: 0.75rem 1.75rem; border-radius: var(--radius);
    font-weight: 600; font-size: 0.95rem; transition: all 0.2s;
  }
  .btn-primary { background: var(--color-accent); color: #1f2937; }
  .btn-primary:hover { background: #d4900a; }
  .btn-outline { border: 2px solid white; color: white; }
  .btn-outline:hover { background: white; color: var(--color-primary); }
  .btn-outline-dark { border: 2px solid var(--color-primary); color: var(--color-primary); }
  .btn-outline-dark:hover { background: var(--color-primary); color: white; }
  .btn-accent { background: var(--color-accent); color: #1f2937; font-size: 1rem; padding: 1rem 2.5rem; }
  .btn-accent:hover { background: #d4900a; }

  .section { padding: 4rem 0; }
  .section-alt { background: var(--color-bg-alt); }
  .section-title { font-size: 1.875rem; font-weight: 700; margin-bottom: 2rem; }
  .section-cta { text-align: center; margin-top: 2.5rem; }

  .grid-3 { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }

  .card {
    background: white; border-radius: var(--radius); overflow: hidden;
    border: 1px solid var(--color-border); transition: box-shadow 0.2s, transform 0.2s;
  }
  .card:hover { box-shadow: 0 8px 24px rgba(0,0,0,0.12); transform: translateY(-2px); }
  .card-img { aspect-ratio: 4/3; overflow: hidden; background: var(--color-bg-alt); }
  .card-img img { width: 100%; height: 100%; object-fit: cover; }
  .placeholder-img { width: 100%; height: 100%; background: linear-gradient(135deg, #e5e7eb, #d1d5db); }
  .card-body { padding: 1.25rem; }
  .card-body h3 { font-size: 1.1rem; font-weight: 600; margin-bottom: 0.25rem; }
  .badge {
    display: inline-block; padding: 0.2rem 0.6rem; border-radius: 99px;
    background: #dcfce7; color: var(--color-primary-dark); font-size: 0.75rem; font-weight: 600;
    text-transform: capitalize; margin-bottom: 0.5rem;
  }
  .text-muted { color: var(--color-muted); font-size: 0.875rem; margin-top: 0.25rem; }

  .cta-section { background: var(--color-primary); color: white; }
  .cta-box { text-align: center; max-width: 560px; margin: 0 auto; }
  .cta-box h2 { font-size: 2rem; font-weight: 700; margin-bottom: 0.75rem; }
  .cta-box p { opacity: 0.9; margin-bottom: 1.75rem; font-size: 1.1rem; }
</style>
