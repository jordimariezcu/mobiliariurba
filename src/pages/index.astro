---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

function getTitle(titol: any): string {
  if (!titol) return '';
  if (typeof titol === 'object' && 'value' in titol) return titol.value;
  return String(titol);
}

let recentPosts: { slug: string; titol: string; descripcio: string | null; categoria: string; data: string | null }[] = [];
try {
  const reader = createReader(process.cwd(), keystaticConfig);
  const allPosts = await reader.collections.blog.all();
  recentPosts = allPosts
    .map((p: any) => ({
      slug: p.slug,
      titol: getTitle(p.entry.titol),
      descripcio: p.entry.descripcio ?? null,
      categoria: p.entry.categoria ?? '',
      data: p.entry.data ?? null,
    }))
    .sort((a, b) => (b.data ?? '').localeCompare(a.data ?? ''))
    .slice(0, 3);
} catch {}

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'MobiliariUrbà.cat',
    url: 'https://mobiliariurba.cat',
    description: 'Portal en català sobre jocs infantils, circuits esportius i mobiliari urbà per a tècnics municipals i arquitectes de Catalunya.',
    inLanguage: 'ca-ES',
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: 'https://mobiliariurba.cat/blog?q={search_term_string}' },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'MobiliariUrbà.cat',
    url: 'https://mobiliariurba.cat',
    logo: 'https://mobiliariurba.cat/og-default.png',
    contactPoint: {
      '@type': 'ContactPoint',
      email: 'info@mobiliariurba.cat',
      contactType: 'customer support',
      availableLanguage: 'Catalan',
    },
  },
]);

const categories = [
  {
    href: '/productes/jocs-infantils',
    titol: 'Jocs Infantils',
    desc: 'Gronxadors, tobogans, jocs inclusius i circuits multijoc. Normativa EN1176 i finançament per a municipis.',
    badge: 'EN1176',
    color: 'blue',
    subs: [
      { href: '/productes/jocs-infantils/gronxadors-i-balancins', nom: 'Gronxadors i Balancins' },
      { href: '/productes/jocs-infantils/tobogans', nom: 'Tobogans' },
      { href: '/productes/jocs-infantils/jocs-inclusius', nom: 'Jocs Inclusius' },
      { href: '/productes/jocs-infantils/circuits-multijoc', nom: 'Circuits Multijoc' },
    ],
  },
  {
    href: '/productes/aparells-biosaludables',
    titol: 'Gent Gran i Biosaludable',
    desc: 'Aparells de baix impacte per a persones grans i circuits de passeig intergeneracionals. Normativa EN16630.',
    badge: 'EN16630',
    color: 'green',
    subs: [
      { href: '/productes/aparells-biosaludables/aparells-gent-gran', nom: 'Aparells per a Gent Gran' },
      { href: '/productes/aparells-biosaludables/circuits-passeig', nom: 'Circuits de Passeig' },
      { href: '/guia/espais-gent-gran', nom: 'Guia Tècnica' },
    ],
  },
  {
    href: '/productes/circuit-esportiu',
    titol: 'Circuit Esportiu',
    desc: 'Cal·listènia, fitness funcional i circuits biosaludables per a adults actius en parcs i espais públics.',
    badge: 'Adults',
    color: 'orange',
    subs: [
      { href: '/productes/circuit-esportiu#calistenia', nom: 'Cal·listènia' },
      { href: '/productes/circuit-esportiu#biosaludable', nom: 'Biosaludable' },
      { href: '/productes/circuit-esportiu#fitness-funcional', nom: 'Fitness Funcional' },
    ],
  },
  {
    href: '/productes/bancs',
    titol: 'Mobiliari Urbà',
    desc: 'Bancs, papereres, fonts, taules de pícnic, pilones i alcorques per a espais públics de qualitat.',
    badge: 'Mobiliari',
    color: 'gray',
    subs: [
      { href: '/productes/bancs', nom: 'Bancs Urbans' },
      { href: '/productes/fonts-i-bebedors', nom: 'Fonts i Bebedors' },
      { href: '/productes/taules-de-picnic', nom: 'Taules de Pícnic' },
      { href: '/productes/papereres', nom: 'Papereres' },
    ],
  },
];

const badgeColors: Record<string, string> = {
  blue: '#dbeafe',
  green: '#dcfce7',
  orange: '#ffedd5',
  gray: '#f3f4f6',
};
const badgeTextColors: Record<string, string> = {
  blue: '#1e40af',
  green: '#166534',
  orange: '#9a3412',
  gray: '#374151',
};
---

<Layout
  title="MobiliariUrbà.cat — Jocs Infantils, Biosaludable i Mobiliari Urbà per a Municipis"
  description="Portal en català sobre jocs infantils, circuits biosaludables per a gent gran i mobiliari urbà per a tècnics municipals de Catalunya. Normativa EN1176 i EN16630, materials i subvencions."
  noSuffix={true}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <p class="hero-kicker">Per a tècnics municipals i arquitectes de Catalunya</p>
        <h1>Equipament urbà<br />per a espais públics</h1>
        <p class="hero-desc">Jocs infantils, zones biosaludables per a gent gran, circuits esportius i mobiliari urbà. Normativa EN1176 i EN16630, subvencions i fabricants homologats.</p>
        <div class="hero-actions">
          <a href="/productes" class="btn btn-accent">Explorar productes</a>
          <a href="/guia/parcs-infantils" class="btn btn-outline">Guies tècniques</a>
        </div>
      </div>
      <div class="hero-stats">
        {[
          { num: 'EN1176', label: 'Jocs infantils' },
          { num: 'EN16630', label: 'Fitness exterior' },
          { num: '4+', label: 'Nínxols de producte' },
          { num: 'CAT', label: 'Contingut en català' },
        ].map(s => (
          <div class="stat-item">
            <strong>{s.num}</strong>
            <span>{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Categories principals -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Àrees de producte</h2>
        <p>Informació tècnica, normativa i orientació de fabricants per a cada categoria d'equipament.</p>
      </div>
      <div class="cats-grid">
        {categories.map(cat => (
          <div class="cat-card">
            <div class="cat-card-top">
              <span class="cat-badge" style={`background:${badgeColors[cat.color]}; color:${badgeTextColors[cat.color]}`}>{cat.badge}</span>
              <h3><a href={cat.href}>{cat.titol}</a></h3>
              <p>{cat.desc}</p>
            </div>
            <ul class="cat-subs">
              {cat.subs.map(s => (
                <li><a href={s.href}>{s.nom} →</a></li>
              ))}
            </ul>
            <a href={cat.href} class="cat-cta">Veure tots →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Per a qui és -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Per a qui és MobiliariUrbà.cat?</h2>
      </div>
      <div class="perfils-grid">
        {[
          { ico: '🏛️', titol: 'Tècnics municipals', desc: 'Informació pràctica sobre normativa, pressupostos orientatius i subvencions per a municipis de Catalunya de qualsevol mida.' },
          { ico: '📐', titol: 'Arquitectes i urbanistes', desc: 'Especificacions tècniques, materials, dimensions i certificacions per incloure als plecs de condicions i memòries descriptives.' },
          { ico: '🏗️', titol: 'Constructors i instal·ladors', desc: 'Guies d\'instal·lació, requisits d\'ancoratge i inspecció, i criteris tècnics per a la posada en obra correcta d\'cada element.' },
        ].map(p => (
          <div class="perfil-card">
            <span class="perfil-ico">{p.ico}</span>
            <h3>{p.titol}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Guies tècniques -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Guies tècniques</h2>
        <p>Recursos pràctics per planificar i gestionar equipaments d'espai públic.</p>
      </div>
      <div class="guies-grid">
        {[
          { href: '/guia/parcs-infantils', titol: 'Planificar un Parc Infantil', desc: 'De la necessitat al projecte: zones de seguretat, normativa EN1176, superfícies i pressupost orientatiu.', badge: 'Parcs infantils' },
          { href: '/guia/normativa-en1176', titol: 'Normativa EN1176', desc: 'Guia pràctica de la norma europea per a tècnics municipals: inspecció, classes d\'ús i responsabilitat legal.', badge: 'Normativa' },
          { href: '/guia/espais-gent-gran', titol: 'Espais per a Gent Gran', desc: 'Com dissenyar i equipar zones biosaludables i circuits de passeig per a persones grans. EN16630 i accessibilitat.', badge: 'Gent gran' },
        ].map(g => (
          <a href={g.href} class="guia-card">
            <span class="guia-badge">{g.badge}</span>
            <h3>{g.titol}</h3>
            <p>{g.desc}</p>
            <span class="guia-link">Llegir la guia →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog recent -->
  {recentPosts.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <div class="section-header">
          <h2>Últims articles</h2>
          <a href="/blog" class="section-link">Veure tots →</a>
        </div>
        <div class="blog-grid">
          {recentPosts.map(post => (
            <a href={`/blog/${post.slug}`} class="blog-card">
              <span class="blog-cat">{post.categoria.replace(/-/g, ' ')}</span>
              <h3>{post.titol}</h3>
              {post.descripcio && <p>{post.descripcio}</p>}
              {post.data && (
                <time datetime={post.data} class="blog-date">
                  {new Date(post.data).toLocaleDateString('ca-ES', { day: 'numeric', month: 'long', year: 'numeric' })}
                </time>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Necessiteu assessorament per al vostre municipi?</h2>
        <p>Connecteu amb especialistes en mobiliari urbà i espais públics a Catalunya. Sense compromís.</p>
        <a href="/contacte" class="btn btn-accent btn-lg">Contactar ara</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero { background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%); color: white; padding: 4.5rem 0 3.5rem; }
  .hero .container { display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: end; }
  .hero-kicker { font-size: 0.85rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.75; margin-bottom: 0.75rem; }
  .hero h1 { font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; line-height: 1.1; margin-bottom: 1.1rem; }
  .hero-desc { font-size: 1.05rem; opacity: 0.88; margin-bottom: 2rem; max-width: 540px; line-height: 1.65; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .stat-item { background: rgba(255,255,255,0.12); border-radius: var(--radius); padding: 0.875rem 1.1rem; text-align: center; }
  .stat-item strong { display: block; font-size: 1.25rem; font-weight: 800; }
  .stat-item span { font-size: 0.75rem; opacity: 0.8; }

  /* Buttons */
  .btn { display: inline-flex; align-items: center; padding: 0.75rem 1.75rem; border-radius: var(--radius); font-weight: 600; font-size: 0.95rem; transition: all 0.2s; text-decoration: none; }
  .btn-accent { background: var(--color-accent); color: #1f2937; }
  .btn-accent:hover { background: #d4900a; }
  .btn-outline { border: 2px solid rgba(255,255,255,0.7); color: white; }
  .btn-outline:hover { background: white; color: var(--color-primary); }
  .btn-lg { font-size: 1.05rem; padding: 0.9rem 2.25rem; }

  /* Sections */
  .section { padding: 4rem 0; }
  .section-alt { background: var(--color-bg-alt); }
  .section-header { margin-bottom: 2rem; }
  .section-header h2 { font-size: 1.75rem; font-weight: 800; margin-bottom: 0.4rem; }
  .section-header p { color: var(--color-muted); font-size: 1rem; }
  .section-header { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; }
  .section-link { font-size: 0.9rem; color: var(--color-primary); font-weight: 600; }
  .section-link:hover { text-decoration: underline; }

  /* Categories grid */
  .cats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; }
  .cat-card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; display: flex; flex-direction: column; gap: 0; transition: box-shadow 0.2s, border-color 0.2s; }
  .cat-card:hover { box-shadow: var(--shadow-md); border-color: var(--color-primary); }
  .cat-card-top { flex: 1; }
  .cat-badge { display: inline-block; font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 999px; margin-bottom: 0.6rem; }
  .cat-card h3 { font-size: 1.1rem; font-weight: 800; margin-bottom: 0.5rem; }
  .cat-card h3 a { color: var(--color-heading); text-decoration: none; }
  .cat-card h3 a:hover { color: var(--color-primary); }
  .cat-card p { font-size: 0.875rem; color: var(--color-muted); line-height: 1.55; margin-bottom: 1rem; }
  .cat-subs { list-style: none; padding: 0; border-top: 1px solid var(--color-border); padding-top: 0.75rem; margin-bottom: 0.75rem; display: flex; flex-direction: column; gap: 0.3rem; }
  .cat-subs a { font-size: 0.82rem; color: var(--color-primary); text-decoration: none; }
  .cat-subs a:hover { text-decoration: underline; }
  .cat-cta { font-size: 0.85rem; font-weight: 700; color: var(--color-primary); text-decoration: none; }
  .cat-cta:hover { text-decoration: underline; }

  /* Perfils */
  .perfils-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; }
  .perfil-card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; }
  .perfil-ico { font-size: 2rem; display: block; margin-bottom: 0.75rem; }
  .perfil-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-heading); }
  .perfil-card p { font-size: 0.875rem; color: var(--color-muted); line-height: 1.6; }

  /* Guies */
  .guies-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; }
  .guia-card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: 0.4rem; transition: box-shadow 0.2s, border-color 0.2s; }
  .guia-card:hover { box-shadow: var(--shadow-md); border-color: var(--color-primary); }
  .guia-badge { font-size: 0.72rem; font-weight: 700; color: var(--color-primary-dark); background: var(--color-primary-light); padding: 0.2rem 0.6rem; border-radius: 999px; display: inline-block; }
  .guia-card h3 { font-size: 1rem; font-weight: 700; color: var(--color-heading); }
  .guia-card p { font-size: 0.875rem; color: var(--color-muted); line-height: 1.55; flex: 1; }
  .guia-link { font-size: 0.85rem; color: var(--color-primary); font-weight: 600; margin-top: 0.25rem; }

  /* Blog */
  .blog-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; }
  .blog-card { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.5rem; text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: 0.5rem; transition: box-shadow 0.2s, border-color 0.2s; }
  .blog-card:hover { box-shadow: var(--shadow-md); border-color: var(--color-primary); }
  .blog-cat { font-size: 0.72rem; font-weight: 700; color: var(--color-primary-dark); background: var(--color-primary-light); padding: 0.2rem 0.6rem; border-radius: 999px; display: inline-block; text-transform: capitalize; }
  .blog-card h3 { font-size: 1rem; font-weight: 700; color: var(--color-heading); line-height: 1.35; }
  .blog-card p { font-size: 0.85rem; color: var(--color-muted); line-height: 1.55; flex: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .blog-date { font-size: 0.78rem; color: var(--color-muted); margin-top: auto; }

  /* CTA */
  .cta-section { background: var(--color-primary); color: white; }
  .cta-box { text-align: center; max-width: 560px; margin: 0 auto; }
  .cta-box h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; margin-bottom: 0.75rem; }
  .cta-box p { opacity: 0.9; margin-bottom: 1.75rem; font-size: 1.05rem; line-height: 1.6; }

  @media (max-width: 900px) {
    .hero .container { grid-template-columns: 1fr; }
    .hero-stats { grid-template-columns: repeat(4, 1fr); }
  }
  @media (max-width: 600px) {
    .hero-stats { display: none; }
    .cats-grid, .guies-grid, .blog-grid { grid-template-columns: 1fr; }
  }
</style>
