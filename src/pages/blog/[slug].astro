---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

function getTitle(titol: any): string {
  if (!titol) return '';
  if (typeof titol === 'object' && 'value' in titol) return titol.value;
  return String(titol);
}

export async function getStaticPaths() {
  try {
    const reader = createReader(process.cwd(), keystaticConfig);
    const posts = await reader.collections.blog.all();
    return posts.map((post: any) => ({ params: { slug: post.slug } }));
  } catch {
    return [];
  }
}

const { slug } = Astro.params;

let titol = '';
let descripcio = '';
let categoria = '';
let data: string | null = null;
let imatge: string | null = null;
let Content: any = null;
let altresPosts: { slug: string; titol: string; categoria: string }[] = [];

try {
  const reader = createReader(process.cwd(), keystaticConfig);
  const post = await reader.collections.blog.read(slug!);
  if (!post) return Astro.redirect('/blog');

  titol = getTitle(post.titol);
  descripcio = post.descripcio ?? '';
  categoria = post.categoria ?? '';
  data = post.data ?? null;
  imatge = post.imatge ?? null;
  Content = await post.contingut();

  const tots = await reader.collections.blog.all();
  altresPosts = tots
    .filter((p: any) => p.slug !== slug)
    .map((p: any) => ({ slug: p.slug, titol: getTitle(p.entry.titol), categoria: p.entry.categoria ?? '' }))
    .slice(0, 4);
} catch {
  return Astro.redirect('/blog');
}

const formattedDate = data
  ? new Date(data).toLocaleDateString('ca-ES', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inici', item: 'https://mobiliariurba.cat' },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://mobiliariurba.cat/blog' },
      { '@type': 'ListItem', position: 3, name: titol, item: `https://mobiliariurba.cat/blog/${slug}` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: titol,
    description: descripcio,
    url: `https://mobiliariurba.cat/blog/${slug}`,
    inLanguage: 'ca-ES',
    ...(data ? { datePublished: data } : {}),
    ...(imatge ? { image: `https://mobiliariurba.cat${imatge}` } : {}),
    author: { '@type': 'Organization', name: 'MobiliariUrbà.cat', url: 'https://mobiliariurba.cat' },
    publisher: { '@type': 'Organization', name: 'MobiliariUrbà.cat', url: 'https://mobiliariurba.cat' },
  },
]);
---

<Layout
  title={titol || slug!}
  description={descripcio}
  ogType="article"
  jsonLd={jsonLd}
>
  <div class="page-header">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inici</a><span>/</span>
        <a href="/blog">Blog</a><span>/</span>
        <span>{titol}</span>
      </nav>
      {categoria && <span class="badge badge-blue" style="margin-bottom:0.75rem;">{categoria}</span>}
      <h1>{titol}</h1>
      {formattedDate && <p class="post-date"><time datetime={data!}>{formattedDate}</time></p>}
    </div>
  </div>

  <section class="section">
    <div class="container post-layout">
      <article class="prose post-content">
        {imatge && <img src={imatge} alt={titol} class="post-hero-img" loading="eager" />}
        {Content && <Content />}
      </article>

      <aside class="post-sidebar">
        <div class="sidebar-card cta-card">
          <h3>Necessiteu assessorament?</h3>
          <p>Connecteu amb especialistes en mobiliari urbà i espais públics a Catalunya.</p>
          <a href="/contacte" class="btn btn-primary" style="width:100%; text-align:center; margin-top:1rem;">Contactar</a>
        </div>
        {altresPosts.length > 0 && (
          <div class="sidebar-card">
            <h3>Més articles</h3>
            <ul class="related-list">
              {altresPosts.map(p => (
                <li>
                  <span class="related-cat">{p.categoria.replace(/-/g, ' ')}</span>
                  <a href={`/blog/${p.slug}`}>{p.titol}</a>
                </li>
              ))}
            </ul>
            <a href="/blog" class="sidebar-all-link">Veure tots els articles →</a>
          </div>
        )}
        <div class="sidebar-card">
          <h3>Guies tècniques</h3>
          <ul class="related-list">
            <li><a href="/guia/parcs-infantils">Guia Parcs Infantils</a></li>
            <li><a href="/guia/normativa-en1176">Normativa EN1176</a></li>
            <li><a href="/guia/espais-gent-gran">Espais per a Gent Gran</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<style>
  .post-date { color: var(--color-muted); font-size: 0.9rem; margin-top: 0.5rem; }
  .post-layout { display: grid; grid-template-columns: 1fr 280px; gap: 3rem; align-items: start; }
  .post-content { min-width: 0; }
  .post-hero-img { width: 100%; height: 360px; object-fit: cover; border-radius: var(--radius-lg); margin-bottom: 2rem; }
  .post-sidebar { display: flex; flex-direction: column; gap: 1.25rem; position: sticky; top: 88px; }
  .sidebar-card { background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.25rem; }
  .sidebar-card h3 { font-size: 0.9rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--color-primary-dark); }
  .cta-card { background: var(--color-primary-light); border-color: var(--color-primary); }
  .cta-card p { font-size: 0.875rem; color: var(--color-muted); line-height: 1.5; }
  .related-list { list-style: none; padding: 0; }
  .related-list li { margin-bottom: 0.6rem; padding-bottom: 0.6rem; border-bottom: 1px solid var(--color-border); }
  .related-list li:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .related-cat { display: block; font-size: 0.7rem; font-weight: 700; text-transform: capitalize; color: var(--color-primary-dark); background: var(--color-primary-light); padding: 0.1rem 0.4rem; border-radius: 99px; display: inline-block; margin-bottom: 0.2rem; }
  .related-list a { font-size: 0.85rem; color: var(--color-heading); display: block; line-height: 1.4; }
  .related-list a:hover { color: var(--color-primary); text-decoration: underline; }
  .sidebar-all-link { display: block; font-size: 0.82rem; font-weight: 600; color: var(--color-primary); margin-top: 0.75rem; text-decoration: none; }
  .sidebar-all-link:hover { text-decoration: underline; }
  @media (max-width: 900px) { .post-layout { grid-template-columns: 1fr; } .post-sidebar { position: static; } }
</style>
